# Supabase Configuration (Add these to .env.local in development)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Analytics
VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here

# Owner UUID — required for web checkout to create transactions in Supabase
# Get from: Supabase Dashboard → Authentication → Users → owner account → copy UUID
VITE_OWNER_ID=your_owner_uuid_here

# Optional: WhatsApp Integration
VITE_WHATSAPP_PHONE=62813xxxxxxxx
